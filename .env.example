# Copy this file to .env and fill in the values
# Never commit .env to git

# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Database
# Leave blank in development to use SQLite
# In production: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# Email (Gmail SMTP — use an App Password, not your real password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
CONTACT_EMAIL=your-email@gmail.com

# Webmail provider for the admin "Open in Mail Client" button
# Options: gmail | outlook | default (system mail app)
VITE_MAIL_PROVIDER=gmail

# Cloudinary (media file storage)
# Leave blank in development to use local disk
# Sign up at: https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Celery (async task queue)
# Leave blank in development to run tasks synchronously (no Redis needed)
# In production: add a Redis service on Railway and set the internal URL here
REDIS_URL=

# Production overrides (set these when deploying)
# DEBUG=False
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
